# Copy to .env.local and fill in real values from your Supabase project.
# Settings -> API -> Project URL and anon public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push VAPID public key (generated via `npx web-push generate-vapid-keys`).
# See supabase/functions/notify-fallback/VAPID.md for setup instructions.
VITE_VAPID_PUBLIC_KEY=
